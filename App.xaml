<Application x:Class="BatteryAging.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cv="clr-namespace:BatteryAging.UI.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BatteryAging;component/UI/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══ 转换器 ═══ -->
            <cv:EnumDescriptionConverter x:Key="EnumDescCv"/>
            <cv:ChannelStatusToBrushConverter x:Key="ChannelStatusBrushCv"/>
            <cv:StepTypeToBrushConverter x:Key="StepTypeBrushCv"/>
            <cv:CurrentSignFormatConverter x:Key="CurrentSignCv"/>
            <cv:InverseBooleanConverter x:Key="InvBoolCv"/>
            <cv:InverseBoolToVisibilityConverter x:Key="InvBoolVisCv"/>
            <cv:StepTypeEqualsToVisibilityConverter x:Key="StepTypeEqVisCv"/>
            <cv:SocToHeightConverter x:Key="SocToHeightCv"/>
            <cv:SocToBrushConverter x:Key="SocToBrushCv"/>
            <BooleanToVisibilityConverter x:Key="BoolVisCv"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
