<Page x:Class="BatteryAging.UI.Pages.DataQueryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      Title="{DynamicResource Main_Nav_Data}"
      Background="{DynamicResource VsBgDeepBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 查询条件 -->
        <Border Grid.Row="0" Style="{StaticResource VsCardStyle}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource DataQuery_StartDate}" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}"/>

                <TextBlock Grid.Column="2" Text="{DynamicResource DataQuery_EndDate}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}"/>

                <TextBlock Grid.Column="4" Text="{DynamicResource DataQuery_BarCode}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <TextBox Grid.Column="5" Text="{Binding BarCode, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="6" Text="{DynamicResource DataQuery_Channel}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <TextBox Grid.Column="7" Text="{Binding ChannelFilter, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>

                <StackPanel Grid.Column="9" Orientation="Horizontal">
                    <Button Style="{StaticResource VsAccentButton}"
                            Command="{Binding QueryCommand}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.Magnify}" Width="13" Height="13" Foreground="White"/>
                            <TextBlock Text="{DynamicResource DataQuery_Query}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource VsOutlinedButton}"
                            Command="{Binding ExportCommand}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.FileExportOutline}" Width="13" Height="13"
                                         Foreground="{StaticResource VsAccentBrush}"/>
                            <TextBlock Text="{DynamicResource DataQuery_ExportCsv}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource VsOutlinedButton}"
                            Command="{Binding ExportExcelCommand}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.FileExportOutline}" Width="13" Height="13"
                                         Foreground="{StaticResource VsAccentBrush}"/>
                            <TextBlock Text="{DynamicResource DataQuery_ExportExcel}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource VsOutlinedButton}"
                            Command="{Binding ExportPdfCommand}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.FileExportOutline}" Width="13" Height="13"
                                         Foreground="{StaticResource VsAccentBrush}"/>
                            <TextBlock Text="{DynamicResource DataQuery_ExportPdf}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 记录列表 -->
        <Border Grid.Row="1" Style="{StaticResource VsCardStyle}" Margin="0,8,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                        BorderBrush="{StaticResource VsBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <TextBlock Text="{DynamicResource DataQuery_Records}" Foreground="{StaticResource VsTextPrimaryBrush}" FontWeight="SemiBold"/>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Records}"
                          SelectedItem="{Binding SelectedRecord}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_ID}" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_Channel}" Binding="{Binding ChannelIndex}" Width="50"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_BarCode}" Binding="{Binding BarCode}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_Recipe}" Binding="{Binding RecipeName}" Width="160"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_Start}" Binding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_End}" Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_Status}" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_Protection}" Binding="{Binding ProtectionTrigger}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_ChargeAh}" Binding="{Binding TotalChargeCapacity, StringFormat={}{0:F4}}" Width="90"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_DischargeAh}" Binding="{Binding TotalDischargeCapacity, StringFormat={}{0:F4}}" Width="90"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_ChargeWh}" Binding="{Binding TotalChargeEnergy, StringFormat={}{0:F4}}" Width="100"/>
                        <DataGridTextColumn Header="{DynamicResource DataQuery_Col_DischargeWh}" Binding="{Binding TotalDischargeEnergy, StringFormat={}{0:F4}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
                <!-- 分页控制 -->
                <Border Grid.Row="2" Background="{StaticResource VsBgHeaderBrush}"
                        BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="0,1,0,0"
                        Padding="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                   Foreground="{StaticResource VsTextSecondaryBrush}">
                            <Run Text="{DynamicResource DataQuery_TotalRecords}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding TotalRecords, Mode=OneWay}"/>
                            <Run Text="{DynamicResource DataQuery_RecordsUnit}"/>
                        </TextBlock>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Command="{Binding FirstPageCommand}" Content="{DynamicResource DataQuery_FirstPage}"
                                    Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                            <Button Command="{Binding PreviousPageCommand}" Content="{DynamicResource DataQuery_PrevPage}"
                                    Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                            <TextBlock VerticalAlignment="Center" Margin="10,0"
                                       Foreground="{StaticResource VsTextPrimaryBrush}" FontFamily="Consolas">
                                <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                            </TextBlock>
                            <Button Command="{Binding NextPageCommand}" Content="{DynamicResource DataQuery_NextPage}"
                                    Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                            <Button Command="{Binding LastPageCommand}" Content="{DynamicResource DataQuery_LastPage}"
                                    Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- 详细数据 -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource VsCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartLine}" Width="14" Height="14"
                                         Foreground="{StaticResource VsAccentBrush}"/>
                            <TextBlock Text="{DynamicResource DataQuery_HistoryCurve}" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Padding="12,6" BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="0,0,0,1"
                            Visibility="{Binding RulSummaryText, Converter={StaticResource StringToVisibilityCv}}">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartLine}" Width="13" Height="13" Foreground="{StaticResource VsAmberBrush}"/>
                            <TextBlock Text="{DynamicResource DataQuery_Rul}" FontWeight="SemiBold" Margin="6,0,6,0"
                                       Foreground="{StaticResource VsTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding RulSummaryText}" Foreground="{StaticResource VsTextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <sp:WpfPlot Grid.Column="0" x:Name="HistoryPlot" Margin="2,4,2,2"/>
                        <sp:WpfPlot Grid.Column="1" x:Name="CyclePlot" Margin="15,4,2,2"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource VsCardStyle}" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <TextBlock Text="{DynamicResource DataQuery_DataPoints}" Foreground="{StaticResource VsTextPrimaryBrush}" FontWeight="SemiBold"/>
                    </Border>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DataPoints}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource DataQuery_Col_TimeS}" Binding="{Binding ElapsedSeconds, StringFormat={}{0:F1}}" Width="70"/>
                            <DataGridTextColumn Header="V" Binding="{Binding Voltage, StringFormat={}{0:F4}}" Width="80"/>
                            <DataGridTextColumn Header="I" Binding="{Binding Current, StringFormat={}{0:F4}}" Width="80"/>
                            <DataGridTextColumn Header="Ah" Binding="{Binding Capacity, StringFormat={}{0:F4}}" Width="80"/>
                            <DataGridTextColumn Header="°C" Binding="{Binding Temperature, StringFormat={}{0:F1}}" Width="60"/>
                            <DataGridTextColumn Header="SOC" Binding="{Binding Soc, StringFormat={}{0:F1}}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Padding="8,4" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource VsTextMutedBrush}" FontSize="11"/>
        </Border>
    </Grid>
</Page>
