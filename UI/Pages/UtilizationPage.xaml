<Page x:Class="BatteryAging.UI.Pages.UtilizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      Title="{DynamicResource Main_Nav_Utilization}"
      Background="{DynamicResource VsBgDeepBrush}">

    <Page.Resources>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 查询条件 -->
        <Border Grid.Row="0" Style="{StaticResource VsCardStyle}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource Utilization_StartDate}" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}"/>

                <TextBlock Grid.Column="2" Text="{DynamicResource Utilization_EndDate}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}"/>

                <TextBlock Grid.Column="4" Text="{DynamicResource Utilization_ElecPrice}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <TextBox Grid.Column="5" Text="{Binding ElectricityPrice, UpdateSourceTrigger=LostFocus}"/>

                <TextBlock Grid.Column="6" Text="{DynamicResource Utilization_FeedbackEff}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <TextBox Grid.Column="7" Text="{Binding FeedbackEfficiency, UpdateSourceTrigger=LostFocus}"/>

                <StackPanel Grid.Column="9" Orientation="Horizontal">
                    <Button Style="{StaticResource VsAccentButton}"
                            Command="{Binding AnalyzeCommand}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.Magnify}" Width="13" Height="13" Foreground="White"/>
                            <TextBlock Text="{DynamicResource Utilization_Analyze}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 汇总统计 -->
        <Border Grid.Row="1" Style="{StaticResource VsCardStyle}" Margin="0,8,0,8">
            <UniformGrid Columns="6" Margin="14,12">
                <StackPanel Margin="4,0">
                    <TextBlock Text="{DynamicResource Utilization_OverallUtil}" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding OverallUtilizationPercent, StringFormat={}{0:F1}%}" Style="{StaticResource StatValue}" Foreground="{StaticResource VsAccentBrush}"/>
                </StackPanel>
                <StackPanel Margin="4,0">
                    <TextBlock Text="{DynamicResource Utilization_PassRate}" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding OverallPassRatePercent, StringFormat={}{0:F1}%}" Style="{StaticResource StatValue}" Foreground="{StaticResource VsSuccessBrush}"/>
                </StackPanel>
                <StackPanel Margin="4,0">
                    <TextBlock Text="{DynamicResource Utilization_ChargeEnergy}" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding TotalChargeEnergyWh, StringFormat={}{0:F1} Wh}" Style="{StaticResource StatValue}"/>
                </StackPanel>
                <StackPanel Margin="4,0">
                    <TextBlock Text="{DynamicResource Utilization_DischargeEnergy}" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding TotalDischargeEnergyWh, StringFormat={}{0:F1} Wh}" Style="{StaticResource StatValue}"/>
                </StackPanel>
                <StackPanel Margin="4,0">
                    <TextBlock Text="{DynamicResource Utilization_FeedbackSaving}" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding FeedbackSavingPercent, StringFormat={}{0:F1}%}" Style="{StaticResource StatValue}" Foreground="{StaticResource VsAmberBrush}"/>
                </StackPanel>
                <StackPanel Margin="4,0">
                    <TextBlock Text="{DynamicResource Utilization_Cost}" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding EstimatedCost, StringFormat={}¥{0:F2}}" Style="{StaticResource StatValue}" Foreground="{StaticResource VsErrorBrush}"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- 分通道明细 -->
        <Border Grid.Row="2" Style="{StaticResource VsCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                        BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="0,0,0,1" Padding="12,6">
                    <TextBlock Text="{DynamicResource Utilization_ChannelDetail}" Foreground="{StaticResource VsTextPrimaryBrush}" FontWeight="SemiBold"/>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ChannelStats}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Utilization_Col_Channel}" Binding="{Binding ChannelIndex}" Width="80"/>
                        <DataGridTextColumn Header="{DynamicResource Utilization_Col_Occupied}" Binding="{Binding OccupiedHours, StringFormat={}{0:F2} h}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource Utilization_Col_Window}" Binding="{Binding WindowHours, StringFormat={}{0:F2} h}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource Utilization_Col_Util}" Binding="{Binding UtilizationPercent, StringFormat={}{0:F1}%}" Width="90"/>
                        <DataGridTextColumn Header="{DynamicResource Utilization_Col_Records}" Binding="{Binding TotalRecords}" Width="80"/>
                        <DataGridTextColumn Header="{DynamicResource Utilization_Col_Passed}" Binding="{Binding PassedRecords}" Width="80"/>
                        <DataGridTextColumn Header="{DynamicResource Utilization_Col_PassRate}" Binding="{Binding PassRatePercent, StringFormat={}{0:F1}%}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="2" Padding="8,4">
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource VsTextMutedBrush}" FontSize="11"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
