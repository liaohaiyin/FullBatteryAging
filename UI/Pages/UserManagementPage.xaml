<Page x:Class="BatteryAging.UI.Pages.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      Title="{DynamicResource UserManagement_PageTitle}"
      Background="{StaticResource VsBgDeepBrush}">

    <Page.Resources>
        <!-- 选项卡：选中/悬停/常态全部使用主题色，修正选中态白底 -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource VsTextMutedBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource VsBgMidBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource VsTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource VsBgPanelBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource VsAccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource VsTextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <TabControl Margin="8" Background="{StaticResource VsBgPanelBrush}" BorderThickness="0">
        <!-- ════════════ 用户 ════════════ -->
        <TabItem Header="{DynamicResource UserManagement_UsersTab}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6">
                        <Button Style="{StaticResource VsFlatButton}" Command="{Binding NewUserCommand}"
                                Content="{DynamicResource UserManagement_NewUser}" Foreground="{StaticResource VsSuccessBrush}"/>
                        <Button Style="{StaticResource VsFlatButton}" Command="{Binding EditUserCommand}"
                                Content="{DynamicResource UserManagement_EditUser}" Foreground="{StaticResource VsAccentBrush}"/>
                        <Button Style="{StaticResource VsFlatButton}" Command="{Binding DeleteUserCommand}"
                                Content="{DynamicResource UserManagement_DeleteUser}" Foreground="{StaticResource VsErrorBrush}"/>
                        <Border Width="1" Background="{StaticResource VsBorderBrush}" Margin="6,4"/>
                        <Button Style="{StaticResource VsFlatButton}" Command="{Binding ResetLockCommand}"
                                Content="{DynamicResource UserManagement_UnlockUser}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource UserManagement_Username}"    Binding="{Binding Username}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource UserManagement_DisplayName}" Binding="{Binding DisplayName}" Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource UserManagement_Role}"        Binding="{Binding Role.Name}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource UserManagement_Email}"       Binding="{Binding Email}" Width="160"/>
                            <DataGridTextColumn Header="{DynamicResource UserManagement_LastLogin}"
                                                Binding="{Binding LastLoginTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                            <DataGridTemplateColumn Header="{DynamicResource UserManagement_AccountStatus}" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToStatusCv}, ConverterParameter='启用|禁用'}"
                                                   Foreground="{Binding IsActive, Converter={StaticResource StatusToColorCv}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="{DynamicResource UserManagement_Locked}" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="🔒" Foreground="{StaticResource VsErrorBrush}"
                                                   Visibility="{Binding IsLocked, Converter={StaticResource BoolVisCv}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- 用户编辑面板 -->
                <Border Grid.Column="1" BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="1,0,0,0"
                        Background="{StaticResource VsBgMidBrush}"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolVisCv}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Text="{Binding EditorHeader}" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

                            <TextBlock Text="{DynamicResource UserManagement_Username}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditUsername}"
                                     IsReadOnly="{Binding IsNewUser, Converter={StaticResource InvBoolCv}}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="{DynamicResource UserManagement_DisplayName}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditDisplayName}" Margin="0,0,0,12"/>

                            <TextBlock Text="{DynamicResource UserManagement_Email}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditEmail}" Margin="0,0,0,12"/>

                            <TextBlock Text="{DynamicResource UserManagement_Role}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding EditRole}"
                                      DisplayMemberPath="Name" Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding PasswordLabel}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="PwdBox" Margin="0,0,0,8" PasswordChanged="PwdBox_Changed"/>
                            <TextBlock Text="{DynamicResource UserManagement_ConfirmPassword}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="ConfirmPwdBox" Margin="0,0,0,12" PasswordChanged="ConfirmPwdBox_Changed"/>

                            <CheckBox IsChecked="{Binding EditIsActive}" Margin="0,0,0,16"
                                      Foreground="{StaticResource VsTextPrimaryBrush}"
                                      IsEnabled="{Binding SelectedUser.IsSystem, Converter={StaticResource InvBoolCv}}"
                                      Content="{DynamicResource UserManagement_AccountEnabled}"/>

                            <TextBlock Text="{Binding FormError}" Foreground="{StaticResource VsErrorBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"
                                       Visibility="{Binding FormError, Converter={StaticResource StringToVisibilityCv}}"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource Save}" Command="{Binding SaveUserCommand}"
                                        Style="{StaticResource VsAccentButton}" Width="80" Margin="0,0,8,0"/>
                                <Button Content="{DynamicResource Cancel}" Command="{Binding CancelUserCommand}"
                                        Style="{StaticResource VsOutlinedButton}" Width="80"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>

        <!-- ════════════ 角色 ════════════ -->
        <TabItem Header="{DynamicResource UserManagement_RolesTab}" Background="{StaticResource VsBgPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6">
                        <Button Style="{StaticResource VsFlatButton}" Command="{Binding NewRoleCommand}"
                                Content="{DynamicResource UserManagement_NewRole}" Foreground="{StaticResource VsSuccessBrush}"/>
                        <Button Style="{StaticResource VsFlatButton}" Command="{Binding EditRoleCommand}"
                                Content="{DynamicResource UserManagement_EditRole}" Foreground="{StaticResource VsAccentBrush}"/>
                        <Button Style="{StaticResource VsFlatButton}" Command="{Binding DeleteRoleCommand}"
                                Content="{DynamicResource UserManagement_DeleteRole}" Foreground="{StaticResource VsErrorBrush}"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                               Foreground="{Binding IsSystem, Converter={StaticResource BoolToColorCv}}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                               Foreground="{StaticResource VsTextMutedBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Border Grid.Column="1" BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="1,0,0,0"
                        Background="{StaticResource VsBgMidBrush}">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 只读信息 -->
                        <StackPanel Grid.Row="0" Visibility="{Binding IsEditingRole, Converter={StaticResource InvBoolVisCv}}">
                            <TextBlock Text="{Binding SelectedRole.Name}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedRole.Description}"
                                       Foreground="{StaticResource VsTextMutedBrush}" Margin="0,4,0,8"/>
                        </StackPanel>

                        <!-- 编辑信息 -->
                        <StackPanel Grid.Row="0" Visibility="{Binding IsEditingRole, Converter={StaticResource BoolVisCv}}">
                            <TextBlock Text="{DynamicResource UserManagement_RoleName}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditRoleName}" Margin="0,0,0,10"/>
                            <TextBlock Text="{DynamicResource Description}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditRoleDescription}" Margin="0,0,0,10"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="{DynamicResource UserManagement_PermissionConfig}"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PermissionItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Border Background="{StaticResource VsBgHeaderBrush}" Padding="8,4" Margin="0,8,0,2"
                                                    Visibility="{Binding IsGroup, Converter={StaticResource BoolVisCv}}">
                                                <TextBlock Text="{Binding GroupName}" FontWeight="Bold" FontSize="12"/>
                                            </Border>
                                            <CheckBox IsChecked="{Binding IsGranted}" Margin="16,2,0,2"
                                                      Foreground="{StaticResource VsTextPrimaryBrush}"
                                                      IsEnabled="{Binding DataContext.IsEditingRole, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      Visibility="{Binding IsGroup, Converter={StaticResource InvBoolVisCv}}"
                                                      Content="{Binding Label}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel Grid.Row="3" Margin="0,12,0,0">
                            <TextBlock Text="{Binding RoleFormError}" Foreground="{StaticResource VsErrorBrush}"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding RoleFormError, Converter={StaticResource StringToVisibilityCv}}"/>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsEditingRole, Converter={StaticResource BoolVisCv}}">
                                <Button Content="{DynamicResource Save}" Command="{Binding SaveRoleCommand}"
                                        Style="{StaticResource VsAccentButton}" Width="80" Margin="0,0,8,0"/>
                                <Button Content="{DynamicResource Cancel}" Command="{Binding CancelRoleCommand}"
                                        Style="{StaticResource VsOutlinedButton}" Width="80"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
