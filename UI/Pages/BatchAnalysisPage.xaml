<Page x:Class="BatteryAging.UI.Pages.BatchAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      xmlns:cv="clr-namespace:BatteryAging.UI.Converters"
      xmlns:ap="clr-namespace:BatteryAging.UI.AttachedProperties"
      Title="{DynamicResource Main_Nav_Batch}"
      Background="{DynamicResource VsBgDeepBrush}">
    <Page.Resources>
        <Style x:Key="CellValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE8F4FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas, Microsoft YaHei"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource VsCardStyle}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource Batch_BarCodePrefix}" VerticalAlignment="Center"
                           Foreground="{StaticResource VsTextSecondaryBrush}" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding BarCodePrefix, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignTextBox}"
                         ap:PlaceholderProperty.PlaceholderText="{DynamicResource Batch_BarCodeHint}"/>

                <TextBlock Grid.Column="2" Text="{DynamicResource Batch_NominalCapacity}" VerticalAlignment="Center"
                           Foreground="{StaticResource VsTextSecondaryBrush}" Margin="20,0,10,0"/>
                <TextBox Grid.Column="3" Text="{Binding NominalCapacity, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F3}}"
                         Style="{StaticResource MaterialDesignTextBox}"/>

                <Button Grid.Column="5"
                        Style="{StaticResource VsAccentButton}"
                        Command="{Binding AnalyzeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ctrl:VsIcon Kind="{StaticResource Icon.ChartBellCurve}" Width="16" Height="16" VerticalAlignment="Center" Foreground="{StaticResource VsTextPrimaryBrush}"/>
                        <TextBlock Text="{DynamicResource Batch_Analyze}" Margin="6,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource VsCardStyle}" Margin="0,12,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                        CornerRadius="3,3,0,0" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <ctrl:VsIcon Kind="{StaticResource Icon.GaugeFull}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Batch_Consistency}" FontWeight="Medium" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <UniformGrid Grid.Row="1" Columns="7" Margin="14,12,14,14">
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{DynamicResource Batch_SampleCount}" Foreground="{StaticResource VsTextSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource ValueNumberStyle}" FontSize="22"
                                   Text="{Binding SampleCount}" Foreground="{StaticResource AccentCyanBrush}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{DynamicResource Batch_MeanCap}" Foreground="{StaticResource VsTextSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource ValueNumberStyle}" FontSize="18"
                                   Text="{Binding MeanCapacity, StringFormat={}{0:F4}}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{DynamicResource Batch_StdDev}" Foreground="{StaticResource VsTextSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource ValueNumberStyle}" FontSize="18"
                                   Text="{Binding StdDevCapacity, StringFormat={}{0:F4}}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{DynamicResource Batch_Range}" Foreground="{StaticResource VsTextSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource ValueNumberStyle}" FontSize="18"
                                   Text="{Binding RangeCapacity, StringFormat={}{0:F4}}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{DynamicResource Batch_MinMax}" Foreground="{StaticResource VsTextSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource CellValueStyle}" FontSize="13">
                            <Run Text="{Binding MinCapacity, StringFormat={}{0:F3}}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding MaxCapacity, StringFormat={}{0:F3}}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{DynamicResource Batch_CV}" Foreground="{StaticResource VsTextSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource ValueNumberStyle}" FontSize="22"
                                   Text="{Binding CvPercent, StringFormat={}{0:F2}}"
                                   Foreground="{StaticResource AccentAmberBrush}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="{DynamicResource Batch_AvgSoh}" Foreground="{StaticResource VsTextSecondaryBrush}"/>
                        <TextBlock Style="{StaticResource ValueNumberStyle}" FontSize="22"
                                   Foreground="{StaticResource AccentGreenBrush}">
                            <Run Text="{Binding AvgSoh, Converter={x:Static cv:SohPercentConverter.Instance}, FallbackValue=0}"/>
                        </TextBlock>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DarkCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource CardHeaderBrush}"
                            CornerRadius="3,3,0,0" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.SortDescending}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Batch_GradeBucket}" FontWeight="Medium" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding GradeBuckets}" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4" Padding="10,8" CornerRadius="3"
                                        Background="{DynamicResource BgMidBrush}"
                                        BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding GradeName}" FontWeight="Bold"
                                                   FontSize="18"
                                                   Foreground="{StaticResource AccentCyanBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding RangeText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}"
                                                   FontSize="20" FontWeight="Bold"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource AccentGreenBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource DarkCardStyle}" Margin="12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource CardHeaderBrush}"
                            CornerRadius="3,3,0,0" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartBar}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Batch_Histogram}" FontWeight="Medium" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Histogram}" Margin="14">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Stretch" Margin="2,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Width="36"
                                               Height="{Binding Count, Converter={x:Static cv:HistogramHeightConverter.Instance}, FallbackValue=0}"
                                               RadiusX="2" RadiusY="2">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#FF00E5FF" Offset="0"/>
                                                <GradientStop Color="#FF2196F3" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <TextBlock Grid.Row="1" Text="{Binding Count}"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource AccentCyanBrush}"
                                               FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Label}"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontFamily="Consolas" FontSize="10"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DarkCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource CardHeaderBrush}"
                            CornerRadius="3,3,0,0" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.FormatListBulleted}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Batch_Records}" FontWeight="Medium" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Records}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              RowHeaderWidth="0" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Batch_Col_Channel}" Binding="{Binding ChannelIndex}" Width="50"/>
                            <DataGridTextColumn Header="{DynamicResource Batch_Col_BarCode}" Binding="{Binding BarCode}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Batch_Col_DischargeAh}" Binding="{Binding TotalDischargeCapacity, StringFormat={}{0:F4}}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource Batch_Col_Soh}" Binding="{Binding SohEstimate, StringFormat={}{0:P1}}" Width="70"/>
                            <DataGridTextColumn Header="{DynamicResource Batch_Col_Grade}" Binding="{Binding Grade}" Width="60"/>
                            <DataGridTextColumn Header="{DynamicResource Batch_Col_EndTime}" Binding="{Binding EndTime, StringFormat={}{0:MM-dd HH:mm}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="8,4" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" Opacity="0.7" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Page>
