<Page x:Class="BatteryAging.UI.Pages.TestExecutionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="http://oxyplot.org/wpf"
      xmlns:ap="clr-namespace:BatteryAging.UI.AttachedProperties"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      Title="测试执行"
      Background="{StaticResource VsBgDeepBrush}">
    <Page.Resources>
        <!-- 通道卡片内部小标签 -->
        <Style x:Key="CellLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Microsoft YaHei"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellUnitStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextMutedBrush}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>
        <Style TargetType="oxy:TrackerControl">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#00C8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Page.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.4*"/>
            <ColumnDefinition Width="1.2*" MinWidth="440"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧：控制条 + 通道矩阵 ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 控制条 -->
            <Border Grid.Row="0" Style="{StaticResource VsCardStyle}" Padding="5,5" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="测试方案" VerticalAlignment="Center"
                               Foreground="{StaticResource VsTextSecondaryBrush}"
                               FontSize="12" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="1"
                              Margin="0,5"
                              ItemsSource="{Binding AvailableRecipes}"
                              SelectedItem="{Binding SelectedRecipe}"
                              DisplayMemberPath="Name"/>

                    <TextBlock Grid.Column="2" Text="电池条码" VerticalAlignment="Center"
                               Foreground="{StaticResource VsTextSecondaryBrush}"
                               FontSize="12" Margin="18,0,10,0"/>
                    <TextBox Grid.Column="3"
                             Margin="0,5"
                             Text="{Binding BarCode, UpdateSourceTrigger=PropertyChanged}"
                             ap:PlaceholderProperty.PlaceholderText="选中通道后输入"
                             Style="{StaticResource MaterialDesignTextBox}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="16"/>

                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button Style="{StaticResource VsAccentButton}"
                                Command="{Binding StartChannelCommand}"
                                ToolTip="启动当前通道"
                                Margin="3,0" Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.Play}" Width="13" Height="13" Foreground="White"/>
                                <TextBlock Text="启动" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Command="{Binding PauseChannelCommand}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.Pause}" Width="13" Height="13"
                                             Foreground="{StaticResource VsWarningBrush}"/>
                                <TextBlock Text="暂停" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Command="{Binding ResumeChannelCommand}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.PlayCircle}" Width="13" Height="13"
                                             Foreground="{StaticResource VsAccentBrush}"/>
                                <TextBlock Text="恢复" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Command="{Binding StopChannelCommand}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.Stop}" Width="13" Height="13"
                                             Foreground="{StaticResource VsErrorBrush}"/>
                                <TextBlock Text="停止" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Border Width="1" Margin="8,2" Background="{StaticResource VsBorderBrush}"/>
                        <Button Style="{StaticResource VsAccentButton}"
                                Command="{Binding StartAllCommand}"
                                ToolTip="启动所有空闲通道"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.PlayBoxMultiple}" 
                                             VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="全部启动" Margin="4,0,0,0" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource TextMutedBrush}"
                                Command="{Binding StopAllCommand}"
                                Margin="3,0" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.StopCircleOutline}" Width="13" Height="13"
                                             Foreground="{StaticResource VsTextSecondaryBrush}"/>
                                <TextBlock Text="全部停止" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 通道矩阵：紧凑横向卡片 4 列 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Channels}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" CornerRadius="4"
                                    Background="{StaticResource VsBgPanelBrush}"
                                    BorderBrush="{StaticResource VsBorderBrush}"
                                    BorderThickness="1"
                                    Height="170">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF000814" Opacity="0.4"
                                                      BlurRadius="6" ShadowDepth="2"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 左侧编号条 -->
                                    <Border Grid.Column="0"
                                            Background="{Binding Status, Converter={StaticResource ChannelStatusBrushCv}}"
                                            CornerRadius="3,0,0,3">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding ShortLabel}"
                                                       Foreground="White"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Row="1" Background="#44000000" Padding="2,3">
                                                <TextBlock Text="{Binding ChannelName}"
                                                           Foreground="White"
                                                           FontSize="9"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.9"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- 右侧数据区 -->
                                    <Grid Grid.Row="1" Margin="8,6,8,6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 时间 -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="时间" Style="{StaticResource CellLabelStyle}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding TotalElapsed}"
                                                   Style="{StaticResource CellValueStyle}"
                                                   HorizontalAlignment="Right"/>

                                        <!-- 电流 -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="电流" Style="{StaticResource CellLabelStyle}"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Current, StringFormat={}{0:F4}, Mode=OneWay}"
                                                       Style="{StaticResource CellValueStyle}"
                                                       Foreground="{StaticResource AccentAmberBrush}"/>
                                            <TextBlock Text="A" Style="{StaticResource CellUnitStyle}"/>
                                        </StackPanel>

                                        <!-- 电压 -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="电压" Style="{StaticResource CellLabelStyle}"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Voltage, StringFormat={}{0:F4}, Mode=OneWay}"
                                                       Style="{StaticResource CellValueStyle}"
                                                       Foreground="{StaticResource AccentCyanBrush}"/>
                                            <TextBlock Text="V" Style="{StaticResource CellUnitStyle}"/>
                                        </StackPanel>

                                        <!-- 容量+温度 同一行 -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="容量" Style="{StaticResource CellLabelStyle}"/>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Capacity, StringFormat={}{0:F3}, Mode=OneWay}"
                                                       Style="{StaticResource CellValueStyle}"
                                                       FontSize="11"/>
                                            <TextBlock Text="Ah" Style="{StaticResource CellUnitStyle}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="温度" Style="{StaticResource CellLabelStyle}"/>
                                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1}, Mode=OneWay}"
                                                       Style="{StaticResource CellValueStyle}"
                                                       FontSize="11"/>
                                            <TextBlock Text="°C" Style="{StaticResource CellUnitStyle}"/>
                                        </StackPanel>

                                        <!-- 工步 -->
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="工步" Style="{StaticResource CellLabelStyle}"/>
                                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Border Background="{Binding CurrentStepType, Converter={StaticResource StepTypeBrushCv}}"
                                                    CornerRadius="2" Padding="4,1">
                                                <TextBlock Text="{Binding CurrentStepType, Converter={StaticResource EnumDescCv}}"
                                                           Foreground="White" FontSize="9"/>
                                            </Border>
                                            <TextBlock Style="{StaticResource CellLabelStyle}" Margin="4,0,0,0">
                                                <Run Text="{Binding CurrentStepIndex, Mode=OneWay}"/>
                                                <Run Text="/"/>
                                                <Run Text="{Binding TotalSteps, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="条码" Style="{StaticResource CellLabelStyle}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1"
                                                   Text="{Binding BarCode, Mode=OneWay}"
                                                   Style="{StaticResource CellValueStyle}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right"/>

                                        <!-- 状态条 -->
                                        <Border Grid.Row="7" Grid.ColumnSpan="2" Margin="0,6,0,0"
                                                Background="#33000000" CornerRadius="2" Padding="5,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="7" Height="7"
                                                             Fill="{Binding Status, Converter={StaticResource ChannelStatusBrushCv}}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Style="{StaticResource CellValueStyle}"
                                                               FontSize="11"
                                                               Margin="5,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding RecipeName}"
                                                           Style="{StaticResource CellLabelStyle}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="120"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 通道选择列表 -->
            <Border Grid.Row="3" Style="{StaticResource VsCardStyle}" Padding="2" Margin="0,5,0,0">
                <ListBox ItemsSource="{Binding Channels}"
                         SelectedItem="{Binding SelectedChannel}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="3"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" CornerRadius="3" Padding="5,2"
                                                Background="{StaticResource VsBgHeaderBrush}"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource VsBorderBrush}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource VsAccentBrush}"/>
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource VsBgActiveBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource VsAccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" Margin="0,0,6,0"
                                         Fill="{Binding Status, Converter={StaticResource ChannelStatusBrushCv}}"/>
                                <TextBlock Text="{Binding ChannelName}" FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource VsTextPrimaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <!-- ═══ 右侧：曲线 + 汇总 + 日志 ═══ -->
        <Grid Grid.Column="1" Margin="14,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <!-- 实时曲线 -->
            <Border Grid.Row="0" Style="{StaticResource VsCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartLine}" VerticalAlignment="Center"
                                         Foreground="{StaticResource AccentCyanBrush}"/>
                            <TextBlock Text="实时曲线" FontWeight="Medium" Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource VsAccentBrush}"/>
                            <Border Background="Transparent"
                                    CornerRadius="2" Padding="6,1" Margin="12,0,0,0">
                                <Border Background="{StaticResource VsBgActiveBrush}"
                                        CornerRadius="2" Padding="6,1" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding SelectedChannel.ChannelName}"
                                               FontSize="11"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Border>
                    <oxy:PlotView Grid.Row="1" x:Name="LivePlot" Background="Transparent" Margin="2,8,2,2"/>
                </Grid>
            </Border>

            <!-- 汇总统计 -->
            <Border Grid.Row="1" Style="{StaticResource VsCardStyle}" Margin="0,12,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartBoxOutline}" Width="14" Height="14"
                                         Foreground="{StaticResource VsAccentBrush}"/>
                            <TextBlock Text="汇总统计" FontWeight="SemiBold" Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <UniformGrid Grid.Row="1" Columns="4" Margin="14,12,14,14">
                        <StackPanel Margin="4,0">
                            <TextBlock Text="充电容量" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource AccentGreenBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalChargeCapacity, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Ah" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <TextBlock Text="放电容量" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource VsSuccessBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalDischargeCapacity, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Ah" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <TextBlock Text="充电能量" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource VsSuccessBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalChargeEnergy, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Wh" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <TextBlock Text="放电能量" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource VsWarningBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalDischargeEnergy, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Wh" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- 日志 -->
            <Border Grid.Row="2" Style="{StaticResource VsCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            CornerRadius="3,3,0,0" Padding="14,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.TextBoxOutline}" Width="14" Height="14"
                                             Foreground="{StaticResource VsAccentBrush}"/>
                                <TextBlock Text="运行日志" FontWeight="SemiBold" Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource VsFlatButton}"
                                    Command="{Binding ClearLogCommand}" Padding="6,2">
                                <StackPanel Orientation="Horizontal">
                                    <ctrl:VsIcon Kind="{StaticResource Icon.DeleteSweep}" Width="13" Height="13"
                                                 Foreground="{StaticResource VsTextSecondaryBrush}"/>
                                    <TextBlock Text="清空" Margin="4,0,0,0" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" Margin="0" VerticalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding LogText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#FFA0D8E8"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 Padding="12,8"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>