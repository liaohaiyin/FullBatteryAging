<Page x:Class="BatteryAging.UI.Pages.TestExecutionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="clr-namespace:OxyPlot.SkiaSharp.Wpf;assembly=OxyPlot.SkiaSharp.Wpf"
      xmlns:ap="clr-namespace:BatteryAging.UI.AttachedProperties"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      xmlns:cv="clr-namespace:BatteryAging.UI.Converters"
      Title="{DynamicResource Main_Nav_Execution}"
      Background="{DynamicResource VsBgDeepBrush}">
    <Page.Resources>
        <Style x:Key="CellLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Microsoft YaHei"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CellUnitStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource VsTextMutedBrush}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>
        <Style x:Key="PanelCollapseToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource VsBgPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="3">
                            <Path x:Name="Arrow" Width="8" Height="12"
                                  Data="M 6 0 L 0 6 L 6 12 Z"
                                  Fill="{StaticResource VsTextSecondaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- IsChecked = 展开状态 → 箭头朝右表示"点此折叠" -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="-1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource VsBgHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.4*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="RightColumn" Width="1.2*" MinWidth="440"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 控制条 -->
            <Border Grid.Row="0" Style="{StaticResource VsCardStyle}" Padding="5,5" Margin="0,0,0,8" HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{DynamicResource TestExec_Recipe}" VerticalAlignment="Center"
                               Foreground="{StaticResource VsTextSecondaryBrush}"
                               FontSize="12" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="1" Margin="0,5"
                              ItemsSource="{Binding AvailableRecipes}"
                              SelectedItem="{Binding SelectedRecipe}"
                              DisplayMemberPath="Name"/>

                    <TextBlock Grid.Column="2" Text="{DynamicResource TestExec_BarCode}" VerticalAlignment="Center"
                               Foreground="{StaticResource VsTextSecondaryBrush}"
                               FontSize="12" Margin="18,0,10,0"/>
                    <TextBox Grid.Column="3" Margin="0,5"
                             Text="{Binding BarCode, UpdateSourceTrigger=PropertyChanged}"
                             ap:PlaceholderProperty.PlaceholderText="{DynamicResource TestExec_BarCodeHint}"
                             Style="{StaticResource MaterialDesignTextBox}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="16"/>

                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                        <Button Style="{StaticResource VsAccentButton}"
                                Command="{Binding StartChannelCommand}"
                                ToolTip="{DynamicResource TestExec_StartTip}"
                                Margin="3,0" Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.Play}" Width="13" Height="13" Foreground="White"/>
                                <TextBlock Text="{DynamicResource Common_Start}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Command="{Binding PauseChannelCommand}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.Pause}" Width="13" Height="13"
                                             Foreground="{StaticResource VsWarningBrush}"/>
                                <TextBlock Text="{DynamicResource Common_Pause}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Command="{Binding ResumeChannelCommand}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.PlayCircle}" Width="13" Height="13"
                                             Foreground="{StaticResource VsAccentBrush}"/>
                                <TextBlock Text="{DynamicResource Common_Resume}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Command="{Binding StopChannelCommand}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.Stop}" Width="13" Height="13"
                                             Foreground="{StaticResource VsErrorBrush}"/>
                                <TextBlock Text="{DynamicResource Common_Stop}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Border Width="1" Margin="8,2" Background="{DynamicResource VsBorderBrush}"/>
                        <Button Style="{StaticResource VsAccentButton}"
                                Command="{Binding StartAllCommand}"
                                ToolTip="{DynamicResource TestExec_StartAllTip}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.PlayBoxMultiple}"
                                             VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="{DynamicResource Common_StartAll}" Margin="4,0,0,0" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsAccentButton}"
                                Command="{Binding SyncStartAllCommand}"
                                ToolTip="{DynamicResource TestExec_SyncStartTip}"
                                Margin="2,0" Padding="10,4">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.PlayBoxMultiple}" VerticalAlignment="Center" Foreground="White"/>
                                <TextBlock Text="{DynamicResource Common_SyncStart}" Margin="4,0,0,0" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsOutlinedButton}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                BorderBrush="{StaticResource TextMutedBrush}"
                                Command="{Binding StopAllCommand}"
                                Margin="3,0" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.StopCircleOutline}" Width="13" Height="13"
                                             Foreground="{StaticResource VsTextSecondaryBrush}"/>
                                <TextBlock Text="{DynamicResource Common_StopAll}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 通道矩阵 -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Channels}"
                     SelectedItem="{Binding SelectedChannel}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4" CornerRadius="4"
                                Background="{DynamicResource VsBgPanelBrush}"
                                Width="200"
                                Height="210"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected,
                                                     RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource VsSuccessBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF000814" Opacity="0.4"
                                                  BlurRadius="6" ShadowDepth="2"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Column="0"
                                        Background="{Binding Status, Converter={StaticResource ChannelStatusBrushCv}}"
                                        CornerRadius="3,0,0,3">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding ShortLabel}"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Row="1" Background="#44000000" Padding="2,3">
                                            <TextBlock Text="{Binding ChannelName}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Opacity="0.9"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="5,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource TestExec_Time}" Style="{StaticResource CellLabelStyle}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                Text="{Binding TotalElapsed,StringFormat={}{0:hh\\:mm\\:ss\\.fff}}"
                                                Style="{StaticResource CellValueStyle}"
                                                HorizontalAlignment="Right"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource TestExec_Current}" Style="{StaticResource CellLabelStyle}"/>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Current, StringFormat={}{0:F4}, Mode=OneWay}"
                                                    Style="{StaticResource CellValueStyle}"
                                                    Foreground="{StaticResource AccentAmberBrush}"/>
                                        <TextBlock Text="A" Style="{StaticResource CellUnitStyle}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource TestExec_Voltage}" Style="{StaticResource CellLabelStyle}"/>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Voltage, StringFormat={}{0:F4}, Mode=OneWay}"
                                                    Style="{StaticResource CellValueStyle}"
                                                    Foreground="{StaticResource AccentCyanBrush}"/>
                                        <TextBlock Text="V" Style="{StaticResource CellUnitStyle}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource TestExec_Capacity}" Style="{StaticResource CellLabelStyle}"/>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Capacity, StringFormat={}{0:F3}, Mode=OneWay}"
                                                    Style="{StaticResource CellValueStyle}"
                                                    FontSize="11"/>
                                        <TextBlock Text="Ah" Style="{StaticResource CellUnitStyle}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource TestExec_Temperature}" Style="{StaticResource CellLabelStyle}"/>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1}, Mode=OneWay}"
                                                    Style="{StaticResource CellValueStyle}"
                                                    FontSize="11"/>
                                        <TextBlock Text="°C" Style="{StaticResource CellUnitStyle}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource TestExec_Power}" Style="{StaticResource CellLabelStyle}"/>
                                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Power, StringFormat={}{0:F2}, Mode=OneWay}" Style="{StaticResource CellValueStyle}" FontSize="11"/>
                                        <TextBlock Text="W" Style="{StaticResource CellUnitStyle}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource TestExec_Step}" Style="{StaticResource CellLabelStyle}"/>
                                    <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Border Background="{Binding CurrentStepType, Converter={StaticResource StepTypeBrushCv}}"
                                                CornerRadius="2" Padding="4,0">
                                            <TextBlock Text="{Binding CurrentStepType, Converter={StaticResource EnumDescCv}}"
                                                        Foreground="White" FontSize="9"/>
                                        </Border>
                                        <TextBlock Style="{StaticResource CellLabelStyle}" Margin="4,0,0,0">
                                            <Run Text="{Binding CurrentStepIndex, Mode=OneWay}"/>
                                            <Run Text="/"/>
                                            <Run Text="{Binding TotalSteps, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource TestExec_BarCodeShort}" Style="{StaticResource CellLabelStyle}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1"
                                                Text="{Binding BarCode, Mode=OneWay}"
                                                Style="{StaticResource CellValueStyle}"
                                                FontSize="11"
                                                HorizontalAlignment="Right"/>

                                    <Border Grid.Row="8" Grid.ColumnSpan="3" Margin="0,6,0,0"
                                            Background="#33000000" CornerRadius="2" Padding="5,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7"
                                                            Fill="{Binding Status, Converter={StaticResource ChannelStatusBrushCv}}"
                                                            VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                            Style="{StaticResource CellValueStyle}"
                                                            FontSize="11"
                                                            Margin="5,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                        Text="{Binding RecipeName}"
                                                        Style="{StaticResource CellLabelStyle}"
                                                        TextTrimming="CharacterEllipsis"
                                                        MaxWidth="120"
                                                        HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="0" Grid.RowSpan="8" Grid.Column="2" HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch" Margin="5,0,0,0">
                                        <Border Width="15" Height="5"
                                                Background="{DynamicResource VsBorderLightBrush}"
                                                CornerRadius="1,1,0,0" HorizontalAlignment="Center"/>
                                        <Border Width="40" Height="90"
                                                BorderBrush="{StaticResource VsBorderLightBrush}"
                                                BorderThickness="2" CornerRadius="3"
                                                Background="#FF101820">
                                            <Grid Margin="2" ClipToBounds="True">
                                                <Rectangle VerticalAlignment="Bottom"
                                                           Fill="{Binding Soc, Converter={x:Static cv:SocToBrushConverter.Instance}}"
                                                           Height="{Binding Soc, Converter={x:Static cv:SocToHeightConverter.Instance}, ConverterParameter=86}"
                                                           RadiusX="1" RadiusY="1" Opacity="0.8"/>
                                                <StackPanel VerticalAlignment="Stretch" Margin="0,4">
                                                    <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,20"/>
                                                    <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,20"/>
                                                    <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,20"/>
                                                    <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,20"/>
                                                </StackPanel>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock FontFamily="Consolas" FontWeight="Bold"
                                                               FontSize="18" Foreground="White"
                                                               HorizontalAlignment="Center">
                                                        <Run Text="{Binding Soc, StringFormat={}{0:F0}, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="SOC %" FontSize="9"
                                                               Foreground="#CCFFFFFF"
                                                               HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 折叠/展开手柄 -->
        <ToggleButton Grid.Column="1" x:Name="CollapseToggle"
                      Width="12" Height="64" Margin="1,0"
                      VerticalAlignment="Center" IsChecked="True"
                      ToolTip="展开/折叠右侧面板"
                      Style="{StaticResource PanelCollapseToggle}"
                      Checked="CollapseToggle_Checked"
                      Unchecked="CollapseToggle_Unchecked"/>

        <!-- ═══ 右侧 ═══ -->
        <Grid Grid.Column="2" x:Name="RightPanel" Margin="2,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource VsCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartLine}" VerticalAlignment="Center"
                                         Foreground="{StaticResource AccentCyanBrush}"/>
                            <TextBlock Text="{DynamicResource TestExec_LiveCurve}" FontWeight="Medium" Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource VsAccentBrush}"/>
                            <Border Background="Transparent"
                                    CornerRadius="2" Padding="6,1" Margin="12,0,0,0">
                                <Border Background="{DynamicResource VsBgActiveBrush}"
                                        CornerRadius="2" Padding="6,1" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding SelectedChannel.ChannelName}"
                                               FontSize="11"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Border>
                    <oxy:PlotView Grid.Row="1" x:Name="LivePlot" Background="Transparent" Margin="2,8,2,2"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource VsCardStyle}" Margin="0,12,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartBoxOutline}" Width="14" Height="14"
                                         Foreground="{StaticResource VsAccentBrush}"/>
                            <TextBlock Text="{DynamicResource TestExec_Summary}" FontWeight="SemiBold" Margin="6,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <UniformGrid Grid.Row="1" Columns="4" Margin="14,12,14,14">
                        <StackPanel Margin="4,0">
                            <TextBlock Text="{DynamicResource TestExec_ChargeCapacity}" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource AccentGreenBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalChargeCapacity, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Ah" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <TextBlock Text="{DynamicResource TestExec_DischargeCapacity}" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource VsSuccessBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalDischargeCapacity, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Ah" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <TextBlock Text="{DynamicResource TestExec_ChargeEnergy}" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource VsSuccessBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalChargeEnergy, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Wh" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="4,0">
                            <TextBlock Text="{DynamicResource TestExec_DischargeEnergy}" Style="{StaticResource ValueLabelStyle}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ValueNumberStyle}"
                                           Foreground="{StaticResource VsWarningBrush}"
                                           FontSize="18"
                                           Text="{Binding SelectedChannel.TotalDischargeEnergy, StringFormat={}{0:F4}, Mode=OneWay}"/>
                                <TextBlock Text="Wh" Style="{StaticResource ValueUnitStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource VsCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                            BorderBrush="{StaticResource VsBorderBrush}"
                            CornerRadius="3,3,0,0" Padding="14,8">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.TextBoxOutline}" Width="14" Height="14"
                                             Foreground="{StaticResource VsAccentBrush}"/>
                                <TextBlock Text="{DynamicResource TestExec_Log}" FontWeight="SemiBold" Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource VsFlatButton}"
                                    Command="{Binding ClearLogCommand}" Padding="6,2">
                                <StackPanel Orientation="Horizontal">
                                    <ctrl:VsIcon Kind="{StaticResource Icon.DeleteSweep}" Width="13" Height="13"
                                                 Foreground="{StaticResource VsTextSecondaryBrush}"/>
                                    <TextBlock Text="{DynamicResource TestExec_ClearLog}" Margin="4,0,0,0" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" Margin="0" VerticalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding LogText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#FFA0D8E8"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 Padding="12,8"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
