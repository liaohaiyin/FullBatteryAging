<Page x:Class="BatteryAging.UI.Pages.ComparisonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      Title="{DynamicResource Main_Nav_Compare}"
      Background="{DynamicResource VsBgDeepBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource VsCardStyle}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource Compare_BarCodePrefix}" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <TextBox Grid.Column="1" Text="{Binding BarCodePrefix, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="2" Style="{StaticResource VsOutlinedButton}" Margin="8,0"
                        Command="{Binding LoadCandidatesCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ctrl:VsIcon Kind="{StaticResource Icon.Magnify}" Width="13" Height="13" Foreground="White"/>
                        <TextBlock Text="{DynamicResource Compare_LoadCandidates}" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="3" Text="{DynamicResource Compare_Mode}" VerticalAlignment="Center" Margin="12,0,8,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <ComboBox Grid.Column="4" x:Name="ModeCombo" SelectedItem="{Binding Mode}"/>

                <Button Grid.Column="6" Style="{StaticResource VsAccentButton}"
                        Command="{Binding BuildComparisonCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ctrl:VsIcon Kind="{StaticResource Icon.ChartLine}" Width="14" Height="14" Foreground="White"/>
                        <TextBlock Text="{DynamicResource Compare_Build}" Margin="6,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource VsCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}" Padding="12,6">
                        <TextBlock Text="{DynamicResource Compare_Candidates}" FontWeight="SemiBold"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Candidates}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Compare_Col_CH}" Binding="{Binding ChannelIndex}" Width="40"/>
                            <DataGridTextColumn Header="{DynamicResource Compare_Col_BarCode}" Binding="{Binding BarCode}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Compare_Col_DischargeAh}" Binding="{Binding TotalDischargeCapacity, StringFormat={}{0:F3}}" Width="80"/>
                            <DataGridTemplateColumn Header="" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource VsFlatButton}" Padding="4,0"
                                                Command="{Binding DataContext.AddCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}">
                                            <ctrl:VsIcon Kind="{StaticResource Icon.Plus}" Width="13" Height="13"
                                                         Foreground="{StaticResource VsSuccessBrush}"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource VsCardStyle}" Margin="8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}" Padding="12,6">
                        <TextBlock Text="{DynamicResource Compare_Selected}" FontWeight="SemiBold"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Selected}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Compare_Col_CH}" Binding="{Binding ChannelIndex}" Width="40"/>
                            <DataGridTextColumn Header="{DynamicResource Compare_Col_BarCode}" Binding="{Binding BarCode}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource VsFlatButton}" Padding="4,0"
                                                Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}">
                                            <ctrl:VsIcon Kind="{StaticResource Icon.Minus}" Width="13" Height="13"
                                                         Foreground="{StaticResource VsErrorBrush}"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource VsCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.ChartLine}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Compare_OverlayCurve}" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <sp:WpfPlot Grid.Row="1" x:Name="ComparePlot" Margin="2,4,2,2"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Padding="8,4" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource VsTextMutedBrush}" FontSize="11"/>
        </Border>
    </Grid>
</Page>
