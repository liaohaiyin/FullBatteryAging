<Page x:Class="BatteryAging.UI.Pages.CabinetManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      Title="{DynamicResource Main_Nav_Cabinet}"
      Background="{StaticResource BgDeepBrush}">

    <Page.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
    </Page.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左：机柜列表 -->
        <Border Grid.Column="0" Style="{StaticResource DarkCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource CardHeaderBrush}"
                        CornerRadius="3,3,0,0" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <ctrl:VsIcon Kind="{StaticResource Icon.ServerNetwork}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Cabinet_List}" FontWeight="Medium" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,8,8,4">
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding NewCabinetCommand}"
                            Foreground="{StaticResource AccentCyanBrush}"
                            ToolTip="{DynamicResource Cabinet_NewTip}" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.Plus}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cabinet_New}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding DeleteCabinetCommand}"
                            Foreground="{StaticResource AccentRedBrush}"
                            ToolTip="{DynamicResource Cabinet_DeleteTip}" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.DeleteOutline}" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cabinet_Delete}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Cabinets}"
                         SelectedItem="{Binding SelectedCabinet}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" CornerRadius="3" Margin="0,2"
                                    Background="{StaticResource BgMidBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <ctrl:VsIcon Kind="{StaticResource Icon.Server}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,4,0,0">
                                        <Run Text="{DynamicResource Cabinet_DriverLabel}"/>
                                        <Run Text="{Binding DriverType, Mode=OneWay}"/>
                                        <Run Text="  "/>
                                        <Run Text="{DynamicResource Cabinet_ChannelLabel}"/>
                                        <Run Text="{Binding ChannelCount, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 右：机柜参数编辑 -->
        <Border Grid.Column="1" Style="{StaticResource DarkCardStyle}" Margin="14,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource CardHeaderBrush}"
                        CornerRadius="3,3,0,0" Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <ctrl:VsIcon Kind="{StaticResource Icon.CogOutline}" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Cabinet_Params}" FontWeight="Medium" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedCabinet}">

                        <TextBlock Text="{DynamicResource Cabinet_BasicInfo}" FontWeight="Medium" FontSize="14"
                                   Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{DynamicResource Cabinet_Name}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{DynamicResource Cabinet_Index}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding CabinetIndex, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="{DynamicResource Cabinet_Type}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding DataContext.CabinetTypes, RelativeSource={RelativeSource AncestorType=Page}}"
                                          DisplayMemberPath="DisplayName" SelectedValuePath="Value"
                                          SelectedValue="{Binding CabinetType}"
                                          Height="25"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderDimBrush}" Margin="0,4,0,12"/>

                        <TextBlock Text="{DynamicResource Cabinet_DriverComm}" FontWeight="Medium" FontSize="14"
                                   Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{DynamicResource Cabinet_Vendor}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding DataContext.DriverTypes, RelativeSource={RelativeSource AncestorType=Page}}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding DriverType}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{DynamicResource Cabinet_ConnType}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding DataContext.ConnectionTypes, RelativeSource={RelativeSource AncestorType=Page}}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding ConnectionType}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{DynamicResource Cabinet_TcpParams}" Style="{StaticResource FieldLabel}"
                                   FontWeight="Medium"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{DynamicResource Cabinet_Ip}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{DynamicResource Cabinet_TcpPort}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{DynamicResource Cabinet_SerialParams}" Style="{StaticResource FieldLabel}"
                                   FontWeight="Medium"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="{DynamicResource Cabinet_SerialPort}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SerialPort, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="{DynamicResource Cabinet_BaudRate}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0">
                                <TextBlock Text="{DynamicResource Cabinet_DataBits}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding DataBits, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="4,0">
                                <TextBlock Text="{DynamicResource Cabinet_StopBits}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding StopBits, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="4,0,0,0">
                                <TextBlock Text="{DynamicResource Cabinet_Parity}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding Parity, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderDimBrush}" Margin="0,4,0,12"/>

                        <TextBlock Text="{DynamicResource Cabinet_ChannelConfig}" FontWeight="Medium" FontSize="14"
                                   Foreground="{StaticResource AccentCyanBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{DynamicResource Cabinet_ChannelStart}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ChannelStartIndex, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="{DynamicResource Cabinet_ChannelCount}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding ChannelCount, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0">
                                <TextBlock Text="{DynamicResource Cabinet_SampleInterval}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Text="{Binding SamplingIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="8,0,0,0">
                                <TextBlock Text="{DynamicResource Cabinet_Enabled}" Style="{StaticResource FieldLabel}"/>
                                <CheckBox IsChecked="{Binding IsEnabled}" Content="{DynamicResource Cabinet_EnableThis}"
                                          Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource Cabinet_Remark}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"/>
                        </StackPanel>

                        <Border Padding="10" Margin="0,8,0,0"
                                Background="#332196F3" CornerRadius="3"
                                BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.InformationOutline}"
                                             Foreground="{StaticResource AccentBlueBrush}"
                                             VerticalAlignment="Top" Margin="0,2,8,0"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                    <Run Text="{DynamicResource Cabinet_InfoPre}"/><Run Foreground="{StaticResource AccentAmberBrush}" FontWeight="Bold" Text="{DynamicResource Cabinet_InfoBold}"/><Run Text="{DynamicResource Cabinet_InfoPost}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="{StaticResource BgMidBrush}" Padding="14,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding SaveCabinetCommand}"
                                Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.ContentSave}" Width="14" Height="14" VerticalAlignment="Center" Foreground="{StaticResource VsTextPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource Cabinet_Save}" Margin="6,0,0,0" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
