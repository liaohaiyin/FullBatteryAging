<Page x:Class="BatteryAging.UI.Pages.AuditLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
      Title="{DynamicResource Main_Nav_AuditLog}"
      Background="{DynamicResource VsBgDeepBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 查询条件 -->
        <Border Grid.Row="0" Style="{StaticResource VsCardStyle}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource AuditLog_StartDate}" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}"/>

                <TextBlock Grid.Column="2" Text="{DynamicResource AuditLog_EndDate}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}"/>

                <TextBlock Grid.Column="4" Text="{DynamicResource AuditLog_User}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <TextBox Grid.Column="5" Text="{Binding UsernameFilter, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="6" Text="{DynamicResource AuditLog_EntityType}" VerticalAlignment="Center" Margin="12,0,6,0"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <TextBox Grid.Column="7" Text="{Binding EntityTypeFilter, UpdateSourceTrigger=PropertyChanged}"/>

                <StackPanel Grid.Column="9" Orientation="Horizontal">
                    <Button Style="{StaticResource VsAccentButton}"
                            Command="{Binding QueryCommand}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.Magnify}" Width="13" Height="13" Foreground="White"/>
                            <TextBlock Text="{DynamicResource AuditLog_Query}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 日志列表 -->
        <Border Grid.Row="1" Style="{StaticResource VsCardStyle}" Margin="0,8,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}"
                        BorderBrush="{StaticResource VsBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <TextBlock Text="{DynamicResource AuditLog_List}" Foreground="{StaticResource VsTextPrimaryBrush}" FontWeight="SemiBold"/>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Logs}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource AuditLog_Col_Time}" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="150"/>
                        <DataGridTextColumn Header="{DynamicResource AuditLog_Col_User}" Binding="{Binding Username}" Width="100"/>
                        <DataGridTextColumn Header="{DynamicResource AuditLog_Col_Action}" Binding="{Binding Action}" Width="90"/>
                        <DataGridTextColumn Header="{DynamicResource AuditLog_Col_EntityType}" Binding="{Binding EntityType}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource AuditLog_Col_EntityId}" Binding="{Binding EntityId}" Width="140"/>
                        <DataGridTextColumn Header="{DynamicResource AuditLog_Col_Detail}" Binding="{Binding Detail}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 分页控制 -->
        <Border Grid.Row="2" Background="{StaticResource VsBgHeaderBrush}"
                BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding StatusText}"
                           Foreground="{StaticResource VsTextSecondaryBrush}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding FirstPageCommand}" Content="{DynamicResource DataQuery_FirstPage}"
                            Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                    <Button Command="{Binding PreviousPageCommand}" Content="{DynamicResource DataQuery_PrevPage}"
                            Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                    <TextBlock VerticalAlignment="Center" Margin="10,0"
                               Foreground="{StaticResource VsTextPrimaryBrush}" FontFamily="Consolas">
                        <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Command="{Binding NextPageCommand}" Content="{DynamicResource DataQuery_NextPage}"
                            Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                    <Button Command="{Binding LastPageCommand}" Content="{DynamicResource DataQuery_LastPage}"
                            Style="{StaticResource VsOutlinedButton}" Margin="2,0" Padding="8,3"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
