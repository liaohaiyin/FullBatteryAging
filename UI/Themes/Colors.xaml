<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Visual Studio Dark Theme 颜色调色板 ═══ -->
    <!-- 参考 VS 2022 Dark 主题 -->

    <!-- 背景色 -->
    <Color x:Key="VsBgDeepColor">#FF1E1E1E</Color>
    <!-- 编辑器主背景 -->
    <Color x:Key="VsBgMidColor">#FF252526</Color>
    <!-- 工具窗口背景 -->
    <Color x:Key="VsBgPanelColor">#FF2D2D30</Color>
    <!-- 面板背景 -->
    <Color x:Key="VsBgHeaderColor">#FF333337</Color>
    <!-- 标题栏 -->
    <Color x:Key="VsBgHoverColor">#FF3E3E40</Color>
    <!-- 悬停 -->
    <Color x:Key="VsBgActiveColor">#FF094771</Color>
    <!-- 选中 (VS list selection) -->
    <Color x:Key="VsBgInputColor">#FF333337</Color>
    <!-- 输入框背景 -->

    <!-- 边框 -->
    <Color x:Key="VsBorderColor">#FF3F3F46</Color>
    <Color x:Key="VsBorderActiveColor">#FF007ACC</Color>
    <Color x:Key="VsBorderLightColor">#FF555558</Color>

    <!-- 强调色 (VS 标志蓝) -->
    <Color x:Key="VsAccentColor">#FF007ACC</Color>
    <Color x:Key="VsAccentHoverColor">#FF1C97EA</Color>
    <Color x:Key="VsAccentDarkColor">#FF005A9E</Color>

    <!-- 状态色 -->
    <Color x:Key="VsSuccessColor">#FF4EC9B0</Color>
    <!-- 青绿(成功/类型) -->
    <Color x:Key="VsWarningColor">#FFD7BA7D</Color>
    <!-- 暖黄(警告) -->
    <Color x:Key="VsErrorColor">#FFF48771</Color>
    <!-- 鲜红(错误) -->
    <Color x:Key="VsInfoColor">#FF9CDCFE</Color>
    <!-- 浅蓝(信息) -->
    <Color x:Key="VsRunningColor">#FF608B4E</Color>
    <!-- 绿(运行/注释) -->
    <Color x:Key="VsAmberColor">#FFCE9178</Color>
    <!-- 字符串色 -->

    <!-- 文本色 -->
    <Color x:Key="VsTextPrimaryColor">#FFF1F1F1</Color>
    <Color x:Key="VsTextSecondaryColor">#FFCCCCCC</Color>
    <Color x:Key="VsTextMutedColor">#FF9B9B9B</Color>
    <Color x:Key="VsTextDisabledColor">#FF656565</Color>

    <!-- ═══ Brushes ═══ -->
    <SolidColorBrush x:Key="VsBgDeepBrush" Color="{StaticResource VsBgDeepColor}"/>
    <SolidColorBrush x:Key="VsBgMidBrush" Color="{StaticResource VsBgMidColor}"/>
    <SolidColorBrush x:Key="VsBgPanelBrush" Color="{StaticResource VsBgPanelColor}"/>
    <SolidColorBrush x:Key="VsBgHeaderBrush" Color="{StaticResource VsBgHeaderColor}"/>
    <SolidColorBrush x:Key="VsBgHoverBrush" Color="{StaticResource VsBgHoverColor}"/>
    <SolidColorBrush x:Key="VsBgActiveBrush" Color="{StaticResource VsBgActiveColor}"/>
    <SolidColorBrush x:Key="VsBgInputBrush" Color="{StaticResource VsBgInputColor}"/>

    <SolidColorBrush x:Key="VsBorderBrush" Color="{StaticResource VsBorderColor}"/>
    <SolidColorBrush x:Key="VsBorderActiveBrush" Color="{StaticResource VsBorderActiveColor}"/>
    <SolidColorBrush x:Key="VsBorderLightBrush" Color="{StaticResource VsBorderLightColor}"/>

    <SolidColorBrush x:Key="VsAccentBrush" Color="{StaticResource VsAccentColor}"/>
    <SolidColorBrush x:Key="VsAccentHoverBrush" Color="{StaticResource VsAccentHoverColor}"/>
    <SolidColorBrush x:Key="VsAccentDarkBrush" Color="{StaticResource VsAccentDarkColor}"/>

    <SolidColorBrush x:Key="VsSuccessBrush" Color="{StaticResource VsSuccessColor}"/>
    <SolidColorBrush x:Key="VsWarningBrush" Color="{StaticResource VsWarningColor}"/>
    <SolidColorBrush x:Key="VsErrorBrush" Color="{StaticResource VsErrorColor}"/>
    <SolidColorBrush x:Key="VsInfoBrush" Color="{StaticResource VsInfoColor}"/>
    <SolidColorBrush x:Key="VsRunningBrush" Color="{StaticResource VsRunningColor}"/>
    <SolidColorBrush x:Key="VsAmberBrush" Color="{StaticResource VsAmberColor}"/>

    <SolidColorBrush x:Key="VsTextPrimaryBrush" Color="{StaticResource VsTextPrimaryColor}"/>
    <SolidColorBrush x:Key="VsTextSecondaryBrush" Color="{StaticResource VsTextSecondaryColor}"/>
    <SolidColorBrush x:Key="VsTextMutedBrush" Color="{StaticResource VsTextMutedColor}"/>
    <SolidColorBrush x:Key="VsTextDisabledBrush" Color="{StaticResource VsTextDisabledColor}"/>

    <!-- ═══ 兼容旧资源名（保留原有键值映射到新主题以减少替换工作量） ═══ -->
    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource VsBgDeepColor}"/>
    <SolidColorBrush x:Key="BgMidBrush" Color="{StaticResource VsBgMidColor}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource VsBgPanelColor}"/>
    <SolidColorBrush x:Key="BgCardHeaderBrush" Color="{StaticResource VsBgHeaderColor}"/>
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource VsAccentColor}"/>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource VsAccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentAmberBrush" Color="{StaticResource VsWarningColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource VsSuccessColor}"/>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource VsErrorColor}"/>
    <SolidColorBrush x:Key="BorderDimBrush" Color="{StaticResource VsBorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource VsTextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource VsTextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource VsTextMutedColor}"/>

    <!-- 顶栏背景 - VS 风格平铺 -->
    <SolidColorBrush x:Key="HeaderBgBrush" Color="{StaticResource VsBgHeaderColor}"/>
    <SolidColorBrush x:Key="CardHeaderBrush" Color="{StaticResource VsBgHeaderColor}"/>
    <SolidColorBrush x:Key="ChannelCardBrush" Color="{StaticResource VsBgPanelColor}"/>

    <!-- MaterialDesign 兼容键，避免引用未定义资源时崩溃 -->
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="{StaticResource VsBgHeaderColor}"/>
    <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="{StaticResource VsBgHeaderColor}"/>
    <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="{StaticResource VsAccentColor}"/>
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="{StaticResource VsBgMidColor}"/>
    <SolidColorBrush x:Key="MaterialDesignBody" Color="{StaticResource VsTextPrimaryColor}"/>

</ResourceDictionary>
