<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/BatteryAging;component/UI/Themes/Colors.xaml"/>
        <ResourceDictionary Source="/BatteryAging;component/UI/Themes/Icons.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- 标题栏按钮基础样式 (无边框、悬停高亮) -->
    <Style x:Key="VsCaptionButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource VsTextPrimaryBrush}"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>                    
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource VsBgHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource VsBgActiveBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 关闭按钮：悬停红色 -->
    <Style x:Key="VsCloseButton" TargetType="Button" BasedOn="{StaticResource VsCaptionButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentRedBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 带标题栏的 Window 样式 -->
    <Style x:Key="VsWindowStyle" TargetType="Window">
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Background" Value="{DynamicResource VsBgDeepBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource VsTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource VsAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="40"
                              ResizeBorderThickness="6"
                              CornerRadius="0"
                              GlassFrameThickness="0"
                              UseAeroCaptionButtons="False"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">
                    <Border x:Name="WinBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 标题栏 -->
                            <Border Grid.Row="0" Background="{DynamicResource VsBgHeaderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 图标 + 标题 -->
                                    <StackPanel Orientation="Horizontal" Margin="10,1,0,0"
                                                VerticalAlignment="Center">
                                        <ctrl:VsIcon Kind="{StaticResource Icon.BatteryChargingHigh}"
                                                     Width="20" Height="20"
                                                     Foreground="{StaticResource VsAccentBrush}"
                                                     VerticalAlignment="Center"/>
                                        <TextBlock Text="{TemplateBinding Title}"
                                                   Foreground="{StaticResource VsTextPrimaryBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <!-- 标题栏按钮 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="PART_MinButton"
                                                Style="{StaticResource VsCaptionButton}"
                                                ToolTip="最小化"
                                                Margin="0,5,0,0">
                                            <!-- 一横 -->
                                            <Path Data="M0,5 L10,5"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="1"
                                                  SnapsToDevicePixels="True"/>
                                        </Button>
                                        <Button x:Name="PART_MaxButton"
                                                Style="{StaticResource VsCaptionButton}"
                                                ToolTip="最大化"
                                                Margin="0,5,0,0">
                                            <Grid Width="10" Height="10">
                                                <!-- 普通: 单方框 -->
                                                <Rectangle x:Name="MaxIcon"
                                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                           StrokeThickness="1"
                                                           Fill="Transparent"
                                                           SnapsToDevicePixels="True"/>
                                                <!-- 还原: 双方框 -->
                                                <Grid x:Name="RestoreIcon" Visibility="Collapsed">
                                                    <Rectangle Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                               StrokeThickness="1"
                                                               Width="8" Height="8"
                                                               HorizontalAlignment="Right" VerticalAlignment="Top"
                                                               Fill="Transparent"
                                                               SnapsToDevicePixels="True"/>
                                                    <Rectangle Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                               StrokeThickness="1"
                                                               Width="8" Height="8"
                                                               HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                               Fill="{StaticResource VsBgHeaderBrush}"
                                                               SnapsToDevicePixels="True"/>
                                                </Grid>
                                            </Grid>
                                        </Button>
                                        <Button x:Name="PART_CloseButton"
                                                Style="{StaticResource VsCloseButton}"
                                                ToolTip="关闭"
                                                Margin="0,5,5,0">
                                            <!-- 叉 -->
                                            <Path Data="M0,0 L10,10 M10,0 L0,10"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="1"
                                                  SnapsToDevicePixels="True"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 内容区 -->
                            <Border x:Name="ContentBorder" Grid.Row="1">
                                <AdornerDecorator>
                                    <ContentPresenter/>
                                </AdornerDecorator>
                            </Border>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="WindowState" Value="Maximized">
                            <!-- 最大化时给内容一点边距，避免被任务栏遮住 -->
                            <Setter TargetName="ContentBorder" Property="Margin" Value="8,0,8,8"/>
                            <Setter TargetName="WinBorder" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="MaxIcon" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="RestoreIcon" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>