<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/BatteryAging;component/UI/Themes/Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- 卡片 / 面板基础样式 (VS 工具窗口风格)                                 -->
    <!-- ════════════════════════════════════════════════════════════════ -->

    <!-- 普通面板卡片：扁平边框 -->
    <Style x:Key="VsCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource VsBgPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- 兼容旧名 -->
    <Style x:Key="DarkCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource VsCardStyle}"/>

    <!-- 通道卡片样式 -->
    <Style x:Key="VsChannelCardStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource VsBgPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- 标签样式                                                            -->
    <!-- ════════════════════════════════════════════════════════════════ -->

    <Style x:Key="ValueLabelStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource VsTextMutedBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
    </Style>

    <Style x:Key="ValueNumberStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Microsoft YaHei"/>
        <Setter Property="Foreground" Value="{StaticResource VsAccentBrush}"/>
    </Style>

    <Style x:Key="ValueUnitStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource VsTextMutedBrush}"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="2,0,0,3"/>
    </Style>

    <!-- 区块标题（用于卡片头） -->
    <Style x:Key="VsSectionHeaderStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource VsTextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei"/>
    </Style>

</ResourceDictionary>
