<Window x:Class="BatteryAging.UI.Windows.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入"
        Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <TextBox x:Name="InputTextBox" Grid.Row="1" VerticalAlignment="Top"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="OkButton"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Content="确定" Width="80" Margin="0,0,8,0"
                    Click="OkButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Content="取消" Width="80"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
