<Window x:Class="BatteryAging.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
        Style="{StaticResource VsWindowStyle}"
        Title="{DynamicResource Main_Title}"
        Height="900" Width="1600"
        MinHeight="700" MinWidth="1280"
        TextElement.Foreground="{StaticResource VsTextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="12"
        FontFamily="Segoe UI, Microsoft YaHei"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>
        <!-- 主体 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 侧边导航 -->
            <Border Grid.Column="0" Background="{DynamicResource VsBgMidBrush}"
                    BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>                       
                
                    <StackPanel Margin="0,8,0,0">
                        <Button x:Name="BtnNavExec"
                                Style="{StaticResource VsFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="16,8"
                                Command="{Binding NavExecutionCommand}"
                                Visibility="{Binding CanExecution, Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.PlayCircleOutline}"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Execution}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="16,8"
                                Command="{Binding NavRecipeCommand}"
                                Visibility="{Binding CanRecipe, Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.FormatListNumbered}"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Recipe}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="16,8"
                                Command="{Binding NavDataCommand}"
                                Visibility="{Binding CanData,Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.DatabaseSearch}"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Data}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="16,8"
                                Command="{Binding NavBatchCommand}"
                                Visibility="{Binding CanStats,Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.BatchAnalysis}"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Batch}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}" HorizontalContentAlignment="Left"
                                Padding="16,8" Command="{Binding NavCompareCommand}"
                                Visibility="{Binding CanStats, Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.ChartLine}" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Compare}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="16,8"
                                Command="{Binding NavCabinetCommand}"
                                Visibility="{Binding CanCabinet,Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.CabinetManager}"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Cabinet}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}" HorizontalContentAlignment="Left"
                                Padding="16,8" Command="{Binding NavUserMgmtCommand}"
                                Visibility="{Binding CanUserMgmt, Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.ServerNetwork}" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_UserMgmt}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}" HorizontalContentAlignment="Left"
                                Padding="16,8" Command="{Binding NavCalibrationCommand}"
                                Visibility="{Binding CanCalibration, Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.CogOutline}" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Calibration}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}" HorizontalContentAlignment="Left"
                                Padding="16,8" Command="{Binding NavAuditLogCommand}"
                                Visibility="{Binding CanAuditLog, Converter={StaticResource BoolVisCv}}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.InformationOutline}" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_AuditLog}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource VsFlatButton}" HorizontalContentAlignment="Left"
                                Padding="16,8" Command="{Binding NavLogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.Logout}" Width="18" Height="18" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_Logout}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Border Height="1" Background="{DynamicResource VsBorderBrush}" Margin="12,8"/>
                        <StackPanel Margin="16,4,16,8">
                            <TextBlock Text="{DynamicResource Main_Theme_Title}" Foreground="{StaticResource VsTextMutedBrush}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="ThemeCombo"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Code"
                                      SelectionChanged="ThemeCombo_SelectionChanged"/>
                        </StackPanel>
                        <Border Height="1" Background="{DynamicResource VsBorderBrush}" Margin="12,16"/>
                        <Button Style="{StaticResource VsFlatButton}"
                                HorizontalContentAlignment="Left"
                                Padding="16,8"
                                Foreground="{StaticResource VsTextSecondaryBrush}"
                                Command="{Binding NavAboutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <ctrl:VsIcon Kind="{StaticResource Icon.InformationOutline}"
                                             Width="18" Height="18"
                                             Foreground="{StaticResource VsTextMutedBrush}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Main_Nav_About}" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>                        
                    </StackPanel>
                    <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                        <TextBlock HorizontalAlignment="Center" FontSize="14" Foreground="{StaticResource VsTextPrimaryBrush}" Text="开发者微信"/>
                        <Viewbox Grid.Row="1" Stretch="Uniform" Margin="10,5,10,20">
                            <Image Source="pack://application:,,,/BatteryAging;component/Resouces/wx.png" Width="48" Height="48" Stretch="Uniform"/>
                        </Viewbox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <Frame Grid.Column="1" NavigationUIVisibility="Hidden" Content="{Binding CurrentPage}"
                   Background="{DynamicResource VsBgDeepBrush}" Grid.ColumnSpan="2"/>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="1" Background="{DynamicResource VsAccentBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                    <Run Text="{DynamicResource Login_UsernameLabel}"/>
                    <Run Text="{Binding CurrentUser}"/>
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0">
                    <Ellipse Width="8" Height="8" Fill="White" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Main_Status_Sim}"
                               Margin="8,0,0,0" VerticalAlignment="Center"
                               FontSize="11" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0">
                    <Border Width="1" Background="{DynamicResource VsBorderBrush}" Margin="8,4"/>
                    <ctrl:VsIcon Kind="{StaticResource Icon.ClockOutline}"
                                 Width="14" Height="14"
                                 Foreground="White"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CurrentTime}"
                               Foreground="White"
                               FontFamily="Consolas, Cascadia Code"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,12,0" FontSize="11"
                           Foreground="White">
                    <Run Text="BatteryAging"/>
                    <Run Text="{Binding Version, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
