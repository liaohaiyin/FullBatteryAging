<Window x:Class="BatteryAging.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:BatteryAging.UI.Controls"
        Title="锂电池充放电老化上位机"
        Height="900" Width="1600"
        MinHeight="700" MinWidth="1280"
        Background="{StaticResource VsBgDeepBrush}"
        TextElement.Foreground="{StaticResource VsTextPrimaryBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="12"
        FontFamily="Segoe UI, Microsoft YaHei"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 (VS 风格紧凑标题栏) -->
        <Border Grid.Row="0" Background="{StaticResource VsBgHeaderBrush}"
                BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="12,0">
                    <ctrl:VsIcon Kind="{StaticResource Icon.BatteryChargingHigh}"
                                 Width="18" Height="18"
                                 Foreground="{StaticResource VsAccentBrush}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="锂电池充放电老化上位机"
                               Foreground="{StaticResource VsTextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                    <Border Background="{StaticResource VsAccentBrush}"
                            CornerRadius="2" Padding="6,1" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="SIMULATION" Foreground="White"
                                   FontSize="9" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding NavTitle}"
                           Foreground="{StaticResource VsTextSecondaryBrush}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0">
                    <ctrl:VsIcon Kind="{StaticResource Icon.ClockOutline}"
                                 Width="14" Height="14"
                                 Foreground="{StaticResource VsTextMutedBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding CurrentTime}"
                               Foreground="{StaticResource VsTextSecondaryBrush}"
                               FontFamily="Consolas, Cascadia Code"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 侧边导航 -->
            <Border Grid.Column="0" Background="{StaticResource VsBgMidBrush}"
                    BorderBrush="{StaticResource VsBorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,8,0,0">
                    <Button x:Name="BtnNavExec"
                            Style="{StaticResource VsFlatButton}"
                            HorizontalContentAlignment="Left"
                            Padding="16,8"
                            Command="{Binding NavExecutionCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.PlayCircleOutline}"
                                         Width="18" Height="18"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="测试执行" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource VsFlatButton}"
                            HorizontalContentAlignment="Left"
                            Padding="16,8"
                            Command="{Binding NavRecipeCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.FormatListNumbered}"
                                         Width="18" Height="18"                                        
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="工步编辑" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource VsFlatButton}"
                            HorizontalContentAlignment="Left"
                            Padding="16,8"
                            Command="{Binding NavDataCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.DatabaseSearch}"
                                         Width="18" Height="18"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="数据查询" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource VsFlatButton}"
                            HorizontalContentAlignment="Left"
                            Padding="16,8"
                            Command="{Binding NavBatchCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.BatchAnalysis}"
                                         Width="18" Height="18"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="批次分析" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource VsFlatButton}"
                            HorizontalContentAlignment="Left"
                            Padding="16,8"
                            Command="{Binding NavCabinetCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.CabinetManager}"
                                         Width="18" Height="18"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="机柜管理" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="{StaticResource VsBorderBrush}" Margin="12,16"/>

                    <Button Style="{StaticResource VsFlatButton}"
                            HorizontalContentAlignment="Left"
                            Padding="16,8"
                            Foreground="{StaticResource VsTextSecondaryBrush}"
                            Command="{Binding NavAboutCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ctrl:VsIcon Kind="{StaticResource Icon.InformationOutline}"
                                         Width="18" Height="18"
                                         Foreground="{StaticResource VsTextMutedBrush}"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="关于" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 内容区 -->
            <Frame Grid.Column="1" NavigationUIVisibility="Hidden" Content="{Binding CurrentPage}"
                   Background="{StaticResource VsBgDeepBrush}"/>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="{StaticResource VsAccentBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="12,0">
                    <Ellipse Width="8" Height="8" Fill="White" VerticalAlignment="Center"/>
                    <TextBlock Text="模拟模式 · 运行中"
                               Margin="8,0,0,0" VerticalAlignment="Center"
                               FontSize="11" Foreground="White"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,12,0" FontSize="11"
                           Foreground="White">
                    <Run Text="BatteryAging"/>
                    <Run Text="{Binding Version, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
